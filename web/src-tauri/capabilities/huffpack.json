{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "huffpack",
  "description": "Permissions for HuffPack Sidecar",
  "windows": ["main"],
  "permissions": [
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "../core/huffpack",
          "sidecar": true
        }
      ]
    },
    "dialog:default"
  ]
}
